# Serveur
PORT=3000

# Superviseur (repli si app_settings.supervisor_pin absent ou vide — défini en base par npm run seed)
SUPERVISOR_PIN=1234

# SQLite
DB_PATH=./data/pauses.db

# Quotas par défaut (si non renseigné en base)
DEFAULT_QUOTA=2

# Durée maximale d'une pause en minutes
MAX_PAUSE_MINUTES=15

# Rétention historique en jours
HISTORY_RETENTION_DAYS=30

# OTA GitHub
GITHUB_OWNER=
GITHUB_REPO=
UPDATE_SCRIPT_PATH=./scripts/update.sh
RESTART_COMMAND=pm2 restart app-pauses
